# Backend API origin used by admin, blog, and frontend plugins.
# Do not include a trailing slash.
VITE_TIPHIA_API_BASE=https://api.example.com

# Static frontend base used by Vite for built asset URLs.
# Root domain deployment:
#   VITE_TIPHIA_FRONTEND_BASE=/
# Custom domain CDN deployment also accepts a full URL or bare domain:
#   VITE_TIPHIA_FRONTEND_BASE=https://tiphia.cairbin.top/
#   VITE_TIPHIA_FRONTEND_BASE=tiphia.cairbin.top
# Subdirectory deployment:
#   VITE_TIPHIA_FRONTEND_BASE=/blog/
# GitHub Pages project path:
#   VITE_TIPHIA_FRONTEND_BASE=/tiphia-frontend/
VITE_TIPHIA_FRONTEND_BASE=/